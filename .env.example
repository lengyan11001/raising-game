# Copy to .env.local and fill real values. .env.local is intentionally ignored.
BYTEPLUS_USERNAME=
BYTEPLUS_ACCOUNT_ID=
BYTEPLUS_LOGIN_URL=

ARK_API_KEY=
BYTEPLUS_ACCESS_KEY_ID=
BYTEPLUS_SECRET_ACCESS_KEY=

SEEDANCE_FAST_ENDPOINT_ID=
SEEDANCE_ENDPOINT_ID=

APIZ_API_KEY=
APIZ_SDK_REPO=https://github.com/xuliang2024/apiz-sdk
USDT_CNY_CENTS=720

NODE_ENV=production
PORT=4174
PGPOOL_MAX=20
PGPOOL_IDLE_TIMEOUT_MS=30000
PGPOOL_CONNECTION_TIMEOUT_MS=5000
PGPOOL_MAX_USES=7500
HTTP_KEEP_ALIVE_TIMEOUT_MS=65000
HTTP_HEADERS_TIMEOUT_MS=70000
HTTP_REQUEST_TIMEOUT_MS=180000
HTTP_MAX_REQUESTS_PER_SOCKET=1000
HTTP_MAX_CONNECTIONS=2000

# Alibaba Cloud Model Studio / Bailian Singapore DashScope endpoint for Advanced Wan2.7.
ALIYUN_DASHSCOPE_API_KEY=
ALIYUN_DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com
ALIYUN_WAN27_MODEL=wan2.7-i2v-2026-04-25
ADVANCED_SEEDANCE_CREDITS_PER_SECOND=150
ADVANCED_WAN27_720P_CREDITS_PER_SECOND=100
ADVANCED_WAN27_1080P_CREDITS_PER_SECOND=150
